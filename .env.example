# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/umera_couture?retryWrites=true&w=majority

# Admin Credentials
ADMIN_EMAIL=umeracouture@gmail.com
ADMIN_PASSWORD=your_secure_password_here

# JWT Secret (generate a random 32+ character string)
JWT_SECRET=your_random_jwt_secret_string_here

# Cloudinary (server-side only — never expose API_SECRET)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Public Site URL
NEXT_PUBLIC_SITE_URL=https://umera-courtue.vercel.app
